{
  "manifest_version": 3,
  "name": "No Authentication on the Popular Website",
  "version": "2.0",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "96": "icon96.png",
    "128": "icon128.png"
  },

  "description": "This addon allows you to visit Pornhub without authentication via third-party sites.",

  "homepage_url": "https://github.com/NiTiSon/no-authentication-on-popular-website",

  "content_scripts": [
    {
      "matches": ["*://*.pornhub.com/*", "*://*.pornhub.org/*"],
      "js": ["main.js"]
    }
  ]
}
